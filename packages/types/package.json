{
  "name": "@demo-dev/types",
  "version": "0.0.2-alpha.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm --outDir dist --clean",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepack": "bun run build"
  }
}
