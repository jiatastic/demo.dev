{
  "name": "demo-dev",
  "version": "0.2.0",
  "description": "Diff-aware PR demo generator for web apps with Playwright continuous capture, FFmpeg composition, and an Agent Skill.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "demo-cli": "./bin/demo-cli.js",
    "demo-dev": "./bin/demo-cli.js"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "skills",
    "README.md",
    "demo.dev.config.example.json",
    "tsconfig.json"
  ],
  "keywords": [
    "pi-package",
    "agent-skill",
    "pr-demo",
    "playwright",
    "ffmpeg",
    "ghost-cursor"
  ],
  "engines": {
    "node": ">=20"
  },
  "pi": {
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm --outDir dist --clean",
    "demo-cli": "tsx src/cli.ts",
    "demo": "tsx src/cli.ts demo",
    "init": "tsx src/cli.ts init",
    "doctor": "tsx src/cli.ts doctor",
    "config": "tsx src/cli.ts config",
    "providers": "tsx src/cli.ts providers",
    "plan": "tsx src/cli.ts plan",
    "probe": "tsx src/cli.ts probe",
    "auth": "tsx src/cli.ts auth",
    "capture": "tsx src/cli.ts capture",
    "voice": "tsx src/cli.ts voice",
    "render": "tsx src/cli.ts render",
    "comment": "tsx src/cli.ts comment",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "citty": "^0.2.2",
    "ghost-cursor-playwright": "^2.1.0",
    "playwright": "^1.52.0",
    "tsx": "^4.19.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3"
  }
}
