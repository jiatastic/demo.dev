{
  "name": "demo-dev-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for demo.dev apps and packages.",
  "type": "module",
  "packageManager": "bun@1.3.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev --parallel",
    "demo-cli": "bun --filter demo-dev demo-cli",
    "demo": "bun --filter demo-dev demo",
    "init": "bun --filter demo-dev init",
    "doctor": "bun --filter demo-dev doctor",
    "config": "bun --filter demo-dev config",
    "providers": "bun --filter demo-dev providers",
    "plan": "bun --filter demo-dev plan",
    "probe": "bun --filter demo-dev probe",
    "auth": "bun --filter demo-dev auth",
    "capture": "bun --filter demo-dev capture",
    "voice": "bun --filter demo-dev voice",
    "render": "bun --filter demo-dev render",
    "comment": "bun --filter demo-dev comment",
    "showcase": "bun apps/cli/src/cli.ts showcase",
    "showcase:web": "bun --filter @demo-dev/web dev"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "tsup": "^8.5.1",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3",
    "wait-on": "^8.0.3"
  }
}
